rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // função: usuário está logado?
    function logado() { return request.auth != null; }

    // função: e-mail do usuário tem doc em /acesso e está ativo?
    function temAcesso() {
      return logado()
        && exists(/databases/$(database)/documents/acesso/$(request.auth.token.email))
        && get(/databases/$(database)/documents/acesso/$(request.auth.token.email)).data.ativo == true;
    }

    // função: é admin ou gestor?
    function ehAdmin() {
      return temAcesso()
        && get(/databases/$(database)/documents/acesso/$(request.auth.token.email)).data.papel in ['admin','gestor'];
    }

    // /acesso: cada um lê o próprio; admin lê/escreve todos
    match /acesso/{email} {
      allow read: if logado() && (request.auth.token.email == email || ehAdmin());
      allow write: if ehAdmin();
    }

    // /config: qualquer usuário com acesso lê; só admin escreve
    match /config/{doc} {
      allow read: if temAcesso();
      allow write: if ehAdmin();
    }

    // /cenarios e subcoleções: com acesso lê; admin escreve tudo;
    // supervisor pode escrever projeção/override (validação fina fica no app)
    match /cenarios/{cid} {
      allow read: if temAcesso();
      allow write: if ehAdmin();

      match /base/{doc} {
        allow read: if temAcesso();
        allow write: if ehAdmin();
      }
      match /projecao/{doc} {
        allow read: if temAcesso();
        allow write: if temAcesso();
      }
      match /overrides/{doc} {
        allow read: if temAcesso();
        allow write: if temAcesso();
      }
      match /projcli/{doc} {
        allow read: if temAcesso();
        allow write: if temAcesso();
      }
      match /realizado/{doc} {
        allow read: if temAcesso();
        allow write: if ehAdmin();
      }
    }
  }
}
